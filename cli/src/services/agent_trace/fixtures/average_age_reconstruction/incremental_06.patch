+type User = {
+  age: number;
+};
+
+export function getAvarageAgeOptimized(users: User[]): number {
+  if (users.length === 0) {
+    return 0;
+  }
+
+  let totalAge = 0;
+
+  for (const user of users) {
+    totalAge += user.age;
+  }
+
+  return totalAge / users.length;
+}
