{
  "$schema": "https://sce.crocoder.dev/config.json",
  "integrations": {
    "target": [
      "claude",
      "opencode",
      "pi"
    ]
  },
  "log_file": "context/tmp/sce.log",
  "log_file_mode": "append",
  "log_level": "error",
  "policies": {
    "attribution_hooks": {
      "enabled": true
    },
    "bash": {
      "custom": [
        {
          "id": "use-nix-flake-check-over-cargo-test",
          "match": {
            "argv_prefix": [
              "cargo",
              "test"
            ]
          },
          "message": "This repository prefers `nix flake check` over direct `cargo test` commands. Run `nix flake check` instead."
        },
        {
          "id": "use-nix-flake-check-over-cargo-fmt-check",
          "match": {
            "argv_prefix": [
              "cargo",
              "fmt",
              "--check"
            ]
          },
          "message": "This repository prefers `nix flake check` over direct `cargo fmt --check`. Run `nix flake check` for verification; keep `cargo fmt` for autofix-only formatting."
        },
        {
          "id": "use-nix-flake-check-over-cargo-check",
          "match": {
            "argv_prefix": [
              "cargo",
              "check"
            ]
          },
          "message": "This repository prefers `nix flake check` over direct `cargo check`. Run `nix flake check` instead."
        }
      ],
      "presets": []
    }
  }
}
