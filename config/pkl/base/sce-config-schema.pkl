import "bash-policy-presets.pkl" as bash_policy_presets
import "../deps/org.json_schema/JsonSchema.pkl"

local presetIds = bash_policy_presets.presets.toList().map((preset) -> preset.id).toListing()

local mutuallyExclusiveConstraints = bash_policy_presets.mutually_exclusive.toList().map((pair) ->
  new JsonSchema {
    not = new JsonSchema {
      allOf = pair.toList().map((id) ->
        new JsonSchema {
          contains = new JsonSchema {
            `const` = id
          }
        }
      ).toListing()
    }
  }
).toListing()

local sceConfigSchema = new JsonSchema {
  $schema = "https://json-schema.org/draft/2020-12/schema"
  $id = "https://sce.crocoder.dev/config.json"
  title = "SCE Config"
  description = "Canonical JSON Schema for global and repo-local sce/config.json files."
  type = "object"
  additionalProperties = false
  properties {
    ["$schema"] = new JsonSchema {
      type = "string"
      `const` = "https://sce.crocoder.dev/config.json"
    }
    ["log_level"] = new JsonSchema {
      type = "string"
      enum = new { "error"; "warn"; "info"; "debug" }
    }
    ["log_format"] = new JsonSchema {
      type = "string"
      enum = new { "text"; "json" }
    }
    ["log_file"] = new JsonSchema {
      type = "string"
      minLength = 1
    }
    ["log_file_mode"] = new JsonSchema {
      type = "string"
      enum = new { "truncate"; "append" }
    }
    ["timeout_ms"] = new JsonSchema {
      type = "integer"
      minimum = 0
    }
    ["workos_client_id"] = new JsonSchema {
      type = "string"
    }
    ["otel"] = new JsonSchema {
      type = "object"
      additionalProperties = false
      properties {
        ["enabled"] = new JsonSchema {
          type = "boolean"
        }
        ["exporter_otlp_endpoint"] = new JsonSchema {
          type = "string"
          format = "uri"
          pattern = "^https?://"
        }
        ["exporter_otlp_protocol"] = new JsonSchema {
          type = "string"
          enum = new { "grpc"; "http/protobuf" }
        }
      }
    }
    ["policies"] = new JsonSchema {
      type = "object"
      additionalProperties = false
      properties {
        ["attribution_hooks"] = new JsonSchema {
          type = "object"
          additionalProperties = false
          properties {
            ["enabled"] = new JsonSchema {
              type = "boolean"
            }
          }
        }
        ["bash"] = new JsonSchema {
          type = "object"
          additionalProperties = false
          properties {
            ["presets"] = new JsonSchema {
              type = "array"
              uniqueItems = true
              items = new JsonSchema {
                type = "string"
                enum = presetIds
              }
              allOf = mutuallyExclusiveConstraints
            }
            ["custom"] = new JsonSchema {
              type = "array"
              items = new JsonSchema {
                type = "object"
                additionalProperties = false
                required = new { "id"; "match"; "message" }
                properties {
                  ["id"] = new JsonSchema {
                    type = "string"
                    minLength = 1
                    not = new JsonSchema {
                      enum = presetIds
                    }
                  }
                  ["match"] = new JsonSchema {
                    type = "object"
                    additionalProperties = false
                    required = new { "argv_prefix" }
                    properties {
                      ["argv_prefix"] = new JsonSchema {
                        type = "array"
                        minItems = 1
                        items = new JsonSchema {
                          type = "string"
                          minLength = 1
                        }
                      }
                    }
                  }
                  ["message"] = new JsonSchema {
                    type = "string"
                    minLength = 1
                  }
                }
              }
            }
          }
        }
      }
    }
  }
  dependentRequired {
    ["log_file_mode"] = new { "log_file" }
  }
}

local jsonRenderer = new JsonRenderer {
  indent = "  "
}

local sceConfigSchemaJson = jsonRenderer.renderDocument(sceConfigSchema)

rendered = sceConfigSchemaJson
