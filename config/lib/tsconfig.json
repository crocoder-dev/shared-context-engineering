{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"types": ["node", "bun"],
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"allowImportingTsExtensions": true,
		"skipLibCheck": true
	},
	"include": [
		"agent-trace-plugin/**/*.ts",
		"bash-policy-plugin/**/*.ts",
		"pi-plugin/**/*.ts"
	],
	"exclude": ["node_modules"]
}
