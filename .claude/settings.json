{
  "$schema": "https://www.schemastore.org/claude-code-settings.json",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sce",
            "args": [
              "hooks",
              "session-model"
            ]
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "sce",
            "args": [
              "hooks",
              "diff-trace"
            ]
          }
        ]
      }
    ]
  }
}