{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "sce hooks session-model"
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit|MultiEdit|NotebookEdit",
				"hooks": [
					{
						"type": "command",
						"command": "sce hooks diff-trace"
					},
					{
						"type": "command",
						"command": "bash .claude/scripts/event-logger.sh"
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/scripts/event-logger.sh"
					}
				]
			}
		],
		"PreToolUse": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/scripts/event-logger.sh"
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/scripts/event-logger.sh"
					}
				]
			}
		]
	}
}